{
  "name": "iii-sandbox",
  "private": true,
  "version": "0.1.0",
  "description": "Docker sandbox platform on iii-engine",
  "license": "Apache-2.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev:worker": "cd packages/worker && cargo run",
